{
  "$schema": "https://json.schemastore.org/web-manifest-combined.json",
  "id": "/?source=pwa",
  "name": "Reaction Heat Energy Calculator",
  "short_name": "ReactionHeat",
  "description": "Draw molecules or enter SMILES and compute reaction enthalpy (delta H) using bond-energy estimation. Offline-capable. No data collection.",
  "lang": "en",
  "dir": "ltr",
  "start_url": "/?source=pwa",
  "scope": "/",
  "display": "standalone",
  "display_override": ["window-controls-overlay", "standalone", "minimal-ui"],
  "orientation": "any",
  "background_color": "#f6f8fb",
  "theme_color": "#4f46e5",
  "categories": ["education", "productivity", "utilities"],
